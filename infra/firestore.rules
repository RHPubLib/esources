// Firestore security rules — deny ALL direct client access.
//
// This service touches Firestore only from Cloud Run via the Admin SDK
// (google-cloud-firestore with a service account), which bypasses these
// rules entirely. No browser/mobile client ever connects directly, so a
// blanket deny is correct and is good defence-in-depth.
//
// Deploy with: firebase deploy --only firestore:rules --project your-library-esources

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
