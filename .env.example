# RHPL eResources service — configuration reference.
# Copy to .env (gitignored) for local development. In production these are
# supplied by Cloud Run: plain values via --set-env-vars, secrets via
# --set-secrets (Secret Manager). See deploy.sh.

# --- GCP -------------------------------------------------------------------
GCP_PROJECT=your-gcp-project-id

# --- Public site -----------------------------------------------------------
# The patron-facing base URL. Used to build the OAuth redirect URI so it is
# correct even though Cloud Run sits behind Firebase Hosting.
PUBLIC_BASE_URL=https://your-eresources-domain.org

# --- Flask session ---------------------------------------------------------
# SECRET_KEY signs the session cookie. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=
# How long a verified off-site patron stays authenticated, in minutes.
SESSION_MINUTES=30

# --- On-campus detection ---------------------------------------------------
# Your library's public IP ranges (CIDR, comma-separated). A patron whose IP falls in
# one of these is treated as in-building and skips the card login.
PUBLIC_CIDRS=
# Number of trusted proxy hops at the END of X-Forwarded-For. 1 = Cloud Run
# only; 2 = Firebase Hosting in front of Cloud Run. VERIFY with /whoami before
# trusting the on-campus bypass — too high a value lets clients spoof their IP.
TRUSTED_PROXY_HOPS=2

# --- Staff admin OAuth (Google) -------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Only Google accounts in this domain may reach /admin.
ADMIN_EMAIL_DOMAIN=your-domain.org

# --- Vendor-password encryption -------------------------------------------
# Fernet key. Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- Polaris PAPI (card verification) -------------------------------------
PAPI_BASE_URL=https://your-polaris-server/PAPIService
PAPI_LANG_ID=1033
PAPI_APP_ID=100
PAPI_ORG_ID=3
PAPI_API_ACCESS_ID=your-papi-app-access-id
PAPI_API_SECRET=

# --- Login rate limiting ---------------------------------------------------
LOGIN_RATE_MAX=5
LOGIN_RATE_WINDOW_MIN=15

# --- Debug -----------------------------------------------------------------
# Set to 1 to expose /whoami (IP-detection diagnostics). Disable in production
# once the on-campus check is verified.
ENABLE_WHOAMI=1
